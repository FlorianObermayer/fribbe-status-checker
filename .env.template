# Environment variable template for fribbe-status-checker.
# For local development: copy to .env.dev and fill in your values.
# For production:        copy to .env alongside your compose file and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────

# Public-facing URL of the app, used for redirects and push callbacks.
APP_URL=https://status.example.com

# Secret key for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=

# Directory where the app stores persistent data (notifications, occupancy history, …).
LOCAL_DATA_PATH=/app/data

# Path to the JSON file that stores API keys.
API_KEYS_PATH=/app/data/secrets/apikeys.json


# ── Auth ──────────────────────────────────────────────────────────────────────

# optional — master credential accepted on all protected endpoints (ADMIN role).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_TOKEN=

# optional — show a "Login" button on the home page for unauthenticated users (default: false).
SHOW_AUTH_BUTTON=false

# optional — redirect all HTTP requests to HTTPS (default: false).
HTTPS_ONLY=false


# ── Presence detection (WLAN) ─────────────────────────────────────────────────
# All three router variables must be set together to enable presence detection.

# optional — IP address of the GL.iNet router to poll for connected devices.
ROUTER_IP=

# optional — router admin credentials.
ROUTER_USERNAME=
ROUTER_PASSWORD=

# optional — how often to poll the router, in seconds (default: 60).
PRESENCE_POLLING_INTERVAL_SECONDS=

# optional — delay before the first presence poll, in seconds (default: 0).
PRESENCE_POLLING_DELAY_SECONDS=

# optional — how often to refresh internal device counts, in seconds (default: 60).
INTERNAL_POLLING_INTERVAL_SECONDS=

# optional — delay before the first internal poll, in seconds (default: 30).
INTERNAL_POLLING_DELAY_SECONDS=


# ── Occupancy scraping ────────────────────────────────────────────────────────

# optional — how often to scrape the booking system for court availability, in seconds (default: 360).
OCCUPANCY_POLLING_INTERVAL_SECONDS=


# ── Web Push notifications (VAPID) ────────────────────────────────────────────
# All three variables must be set together to enable push notifications.
# Generate keys with: uv run generate-vapid-keys

# optional — VAPID private key for signing push requests.
VAPID_PRIVATE_KEY=

# optional — VAPID public key sent to push subscribers.
VAPID_PUBLIC_KEY=

# optional — contact URI included in the VAPID claim (e.g. mailto:you@example.com).
VAPID_CLAIM_SUBJECT=


# ── Weather (OpenWeatherMap) ──────────────────────────────────────────────────
# All three variables must be set together to enable weather-aware push messages.

# optional — OpenWeatherMap API key.
OPENWEATHERMAP_API_KEY=

# optional — latitude of the venue (e.g. 48.1234).
WEATHER_LAT=

# optional — longitude of the venue (e.g. 11.5678).
WEATHER_LON=

# optional — how long to cache weather data, in seconds (default: 1800).
WEATHER_CACHE_TTL_SECONDS=


# ── Miscellaneous ─────────────────────────────────────────────────────────────

# optional — IANA timezone name for all local datetime calculations (default: Europe/Berlin).
TZ=Europe/Berlin

# optional — domain appended to all Content-Security-Policy source lists
# (e.g. https://*.example.com). When unset, only 'self' is used.
CSP_DOMAIN=

# optional — operator name and email displayed on the /legal page.
# Both must be set to enable the legal page.
OPERATOR_NAME=
OPERATOR_EMAIL=