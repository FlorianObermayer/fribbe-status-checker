{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.dev",
            "jinja2": true,
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env.dev"
        },
        {
            "name": "Python: Run (watch)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.watch",
            "jinja2": true,
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env.dev"
        }
    ]
}